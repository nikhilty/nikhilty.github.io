  .fp-target-note { margin-top: 1rem; padding: 0.7rem 0.9rem; background: rgba(99, 102, 241, 0.1); border: 1px solid rgba(99, 102, 241, 0.2); border-radius: 10px; font-size: 0.9rem; color: #d0d0dd; text-align: center; }
