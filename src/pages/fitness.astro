    z-index: 99;
    background: #0a0a0f;
    border-bottom: 1px solid #1e1e2e;
    margin-bottom: 1rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .fp-tabs::-webkit-scrollbar { display: none; }
  .fp-tab {
    flex-shrink: 0;
    padding: 0.5rem 1.1rem;
    border: 1px solid #2a2a3d;
    border-radius: 100px;
    background: transparent;
    color: #9595a8;
    font-size: 0.85rem;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .fp-tab.active {
    background: #6366f1;
    border-color: #6366f1;
    color: #fff;
  }

  /* ===== Panels & Grid ===== */
  .fp-panel { display: none; }
  .fp-panel.active { display: block; }
  .fp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  /* ===== Cards ===== */
  .fp-card {
    background: #16161f;
    border: 1px solid #1e1e2e;
    border-radius: 14px;
    overflow: hidden;
  }
  .fp-card--full { grid-column: 1 / -1; }
  .fp-card-head {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.9rem 1rem;
    font-size: 1rem;
    font-weight: 600;
    color: #f0f0f5;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .fp-card-head::-webkit-details-marker { display: none; }
  .fp-card-head::after {
    content: '+';
    margin-left: auto;
    font-size: 1.2rem;
    color: #5c5c70;
    font-weight: 300;
    transition: transform 0.2s;
    flex-shrink: 0;
  }
  details[open] > .fp-card-head::after { content: '\2212'; }
  .fp-card-head--static { cursor: default; }
  .fp-card-head--static::after { display: none; }
  .fp-card-head small {
    font-weight: 400;
    color: #5c5c70;
    font-size: 0.78rem;
    margin-left: 0.25rem;
  }
  .fp-icon { font-size: 1.15rem; line-height: 1; }
  .fp-card-body { padding: 0 1rem 1rem; }
  .fp-card-body h4 {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #818cf8;
    margin: 0.85rem 0 0.4rem;
  }
  .fp-avoid-label { color: #f87171 !important; }
  .fp-note {
