  }
  .fp-demo:hover { background: rgba(99, 102, 241, 0.2); color: #a5b4fc; }

  /* ===== Schedule ===== */
  .fp-schedule { display: grid; grid-template-columns: repeat(7, 1fr); gap: 0.35rem; }
