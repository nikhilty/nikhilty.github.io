  /* ===== Steps Grid ===== */
  .fp-steps-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.5rem; }
  .fp-step-week { padding: 0.65rem 0.8rem; background: #1c1c28; border: 1px solid #2a2a3d; border-radius: 10px; text-align: center; }
  .fp-step-week--target { background: rgba(99, 102, 241, 0.12); border-color: rgba(99, 102, 241, 0.3); }
  .fp-step-label { display: block; font-size: 0.7rem; font-weight: 600; text-transform: uppercase; color: #5c5c70; margin-bottom: 0.15rem; }
