---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nikhil — Fat Loss Plan" description="Complete fat loss meal and workout plan">
<div class="fp">
  <header class="fp-header">
    <a href="/" class="fp-back" aria-label="Back to portfolio">&larr;</a>
    <div>
      <h1 class="fp-title">Fat Loss Plan</h1>
      <p class="fp-stats">6'3" &middot; 130kg &rarr; 120kg &middot; 4 days/week</p>
    </div>
  </header>

  <nav class="fp-tabs" id="tabs">
    <button class="fp-tab active" data-tab="meals">Meals</button>
    <button class="fp-tab" data-tab="workouts">Workouts</button>
    <button class="fp-tab" data-tab="track">Track</button>
    <button class="fp-tab" data-tab="extras">Steps & More</button>
  </nav>

  <!-- ==================== MEALS TAB ==================== -->
  <div class="fp-panel active" id="panel-meals">
    <div class="fp-grid">

    <!-- Pre-Workout -->
    <details class="fp-card">
      <summary class="fp-card-head">
        <span class="fp-icon">&#9728;</span>
        <span>Pre-Workout <small>(optional)</small></span>
      </summary>
      <div class="fp-card-body">
        <p class="fp-note">If training within 30 min of waking. Fasted is fine if energy is good.</p>
        <ul class="fp-options">
          <li><strong>A</strong> 1 banana + black coffee</li>
          <li><strong>B</strong> 2 dates + black coffee</li>
          <li><strong>C</strong> Water + coffee</li>
        </ul>
      </div>
    </details>

    <!-- Breakfast -->
    <details class="fp-card" open>
      <summary class="fp-card-head">
        <span class="fp-icon">&#127859;</span>
        <span>Breakfast</span>
      </summary>
      <div class="fp-card-body">
        <div class="fp-macro-row">
          <span class="fp-chip">2 whole eggs</span>
          <span class="fp-chip">4 egg whites</span>
          <span class="fp-chip">300ml milk (3.25%)</span>
          <span class="fp-chip">1 fruit</span>
          <span class="fp-chip">1 serving seeds</span>
        </div>
        <h4>Combos</h4>
        <ul class="fp-options">
          <li>Omelette + apple + milk</li>
          <li>Boiled eggs + banana + milk</li>
          <li>Scrambled eggs w/ spinach + orange + milk</li>
        </ul>
        <h4>Seed pick (choose 1 tbsp)</h4>
        <div class="fp-macro-row">
          <span class="fp-chip fp-chip--green">Pumpkin</span>
          <span class="fp-chip fp-chip--green">Chia</span>
          <span class="fp-chip">Flax</span>
        </div>
      </div>
    </details>

    <!-- Lunch -->
    <details class="fp-card" open>
      <summary class="fp-card-head">
        <span class="fp-icon">&#127858;</span>
        <span>Lunch</span>
      </summary>
      <div class="fp-card-body">
        <div class="fp-macro-row">
          <span class="fp-chip">150g paneer</span>
          <span class="fp-chip">150g Greek yogurt</span>
          <span class="fp-chip">75g rice <em>or</em> 3 rotis</span>
          <span class="fp-chip">5g oil</span>
        </div>
        <h4>Paneer Rice Bowl</h4>
        <ol class="fp-steps-list">
          <li>Cook rice</li>
          <li>Cook paneer with 5g oil + spices</li>
          <li>Serve with yogurt on the side</li>
        </ol>
      </div>
    </details>

    <!-- Dinner -->
    <details class="fp-card" open>
      <summary class="fp-card-head">
        <span class="fp-icon">&#127769;</span>
        <span>Dinner</span>
      </summary>
      <div class="fp-card-body">
        <div class="fp-macro-row">
          <span class="fp-chip">40g soya chunks</span>
          <span class="fp-chip">40g rajma/chickpeas/lentils</span>
          <span class="fp-chip">150g veggies</span>
          <span class="fp-chip">75g rice</span>
          <span class="fp-chip">10g oil</span>
        </div>
        <h4>Soya-Dal Bowl</h4>
        <ol class="fp-steps-list">
          <li>Cook rice + boil soya</li>
          <li>Cook dal</li>
          <li>Stir-fry veggies</li>
          <li>Mix and serve</li>
        </ol>
      </div>
    </details>

    <!-- Vegetables -->
    <details class="fp-card">
      <summary class="fp-card-head">
        <span class="fp-icon">&#129382;</span>
        <span>Vegetables</span>
      </summary>
      <div class="fp-card-body">
        <h4>Excellent</h4>
        <div class="fp-macro-row">
          <span class="fp-chip fp-chip--green">Brussels sprouts</span>
          <span class="fp-chip fp-chip--green">Broccoli</span>
          <span class="fp-chip fp-chip--green">Cauliflower</span>
          <span class="fp-chip fp-chip--green">Spinach</span>
          <span class="fp-chip fp-chip--green">Green beans</span>
          <span class="fp-chip fp-chip--green">Cabbage</span>
          <span class="fp-chip fp-chip--green">Zucchini</span>
          <span class="fp-chip fp-chip--green">Asparagus</span>
        </div>
        <h4>Good</h4>
        <div class="fp-macro-row">
          <span class="fp-chip">Carrots</span>
          <span class="fp-chip">Capsicum</span>
          <span class="fp-chip">Mushrooms</span>
          <span class="fp-chip">Peas</span>
        </div>
        <h4>Salad (unlimited)</h4>
        <div class="fp-macro-row">
          <span class="fp-chip">Cucumber</span>
          <span class="fp-chip">Tomatoes</span>
          <span class="fp-chip">Lettuce</span>
        </div>
      </div>
    </details>

    <!-- Fruits -->
    <details class="fp-card">
      <summary class="fp-card-head">
        <span class="fp-icon">&#127822;</span>
        <span>Fruits <small>(1 daily)</small></span>
      </summary>
      <div class="fp-card-body">
        <h4>Best</h4>
        <div class="fp-macro-row">
          <span class="fp-chip fp-chip--green">Apple</span>
          <span class="fp-chip fp-chip--green">Orange</span>
          <span class="fp-chip fp-chip--green">Guava</span>
          <span class="fp-chip fp-chip--green">Pear</span>
          <span class="fp-chip fp-chip--green">Kiwi</span>
        </div>
        <h4>Fine</h4>
        <div class="fp-macro-row">
          <span class="fp-chip">Banana</span>
          <span class="fp-chip">Mango</span>
          <span class="fp-chip">Grapes</span>
          <span class="fp-chip">Pineapple</span>
          <span class="fp-chip">Pomegranate</span>
        </div>
      </div>
    </details>

    <!-- Drinks -->
    <details class="fp-card">
      <summary class="fp-card-head">
        <span class="fp-icon">&#129380;</span>
        <span>Drinks</span>
      </summary>
      <div class="fp-card-body">
        <h4>Best</h4>
        <div class="fp-macro-row">
          <span class="fp-chip fp-chip--green">Water</span>
          <span class="fp-chip fp-chip--green">Sparkling water</span>
          <span class="fp-chip fp-chip--green">Black coffee</span>
          <span class="fp-chip fp-chip--green">Green tea</span>
        </div>
        <h4>Allowed (max 1/day)</h4>
        <div class="fp-macro-row">
          <span class="fp-chip">Coke Zero</span>
          <span class="fp-chip">Diet Coke</span>
        </div>
      </div>
    </details>

    <!-- Snacks -->
    <details class="fp-card">
      <summary class="fp-card-head">
        <span class="fp-icon">&#127839;</span>
        <span>Snacks</span>
      </summary>
      <div class="fp-card-body">
        <h4>Tier 1</h4>
        <div class="fp-macro-row">
          <span class="fp-chip fp-chip--green">Boiled eggs</span>
          <span class="fp-chip fp-chip--green">Greek yogurt</span>
          <span class="fp-chip fp-chip--green">Roasted chana</span>
        </div>
        <h4>Tier 2</h4>
        <div class="fp-macro-row">
          <span class="fp-chip">Paneer tikka</span>
          <span class="fp-chip">Sprouts chaat</span>
        </div>
        <h4>Tier 3</h4>
        <div class="fp-macro-row">
          <span class="fp-chip">Protein restaurant food</span>
        </div>
        <h4 class="fp-avoid-label">Avoid</h4>
        <div class="fp-macro-row">
          <span class="fp-chip fp-chip--red">Samosas</span>
          <span class="fp-chip fp-chip--red">Fries</span>
          <span class="fp-chip fp-chip--red">Pizza</span>
          <span class="fp-chip fp-chip--red">Chips</span>
          <span class="fp-chip fp-chip--red">Cookies</span>
          <span class="fp-chip fp-chip--red">Donuts</span>
        </div>
      </div>
    </details>

    </div>
  </div>

  <!-- ==================== WORKOUTS TAB ==================== -->
  <div class="fp-panel" id="panel-workouts">
    <div class="fp-grid">

    <!-- Weekly Schedule -->
    <div class="fp-card fp-card--open fp-card--full">
      <div class="fp-card-head fp-card-head--static">
        <span class="fp-icon">&#128197;</span>
        <span>Weekly Schedule</span>
      </div>
      <div class="fp-card-body">
        <div class="fp-schedule">
          <div class="fp-day"><span class="fp-day-name">Mon</span><span class="fp-day-workout">Upper A</span></div>
          <div class="fp-day"><span class="fp-day-name">Tue</span><span class="fp-day-workout">Lower A</span></div>
          <div class="fp-day fp-day--rest"><span class="fp-day-name">Wed</span><span class="fp-day-workout">Walk + Mobility</span></div>
          <div class="fp-day"><span class="fp-day-name">Thu</span><span class="fp-day-workout">Upper B</span></div>
          <div class="fp-day"><span class="fp-day-name">Fri</span><span class="fp-day-workout">Lower B</span></div>
          <div class="fp-day fp-day--rest"><span class="fp-day-name">Sat</span><span class="fp-day-workout">Light walk</span></div>
          <div class="fp-day fp-day--rest"><span class="fp-day-name">Sun</span><span class="fp-day-workout">Rest</span></div>
        </div>
      </div>
    </div>

    <!-- Warm-Up -->
    <details class="fp-card fp-card--full">
      <summary class="fp-card-head">
        <span class="fp-icon">&#128293;</span>
        <span>Warm-Up <small>(before every session)</small></span>
      </summary>
      <div class="fp-card-body">
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Stationary Bike</div>
              <div class="fp-ex-sets">5&ndash;10 min</div>
            </div>
          </div>
          <div class="fp-ex-detail">Easy pace to raise heart rate and warm joints.</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Arm Circles</div>
              <div class="fp-ex-sets">10 forward + 10 backward</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=arm+circles+warm+up+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Big circles, full range. Loosens shoulder capsule.</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Band Pull-Aparts</div>
              <div class="fp-ex-sets">15 reps</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=band+pull+aparts+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Hold band at shoulder width, pull apart to chest. Activates rear delts and rotator cuff.</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Bodyweight Box Squat</div>
              <div class="fp-ex-sets">10 reps</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=bodyweight+box+squat+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Squat to a bench/box. Pain-free range only &mdash; skip if knee hurts.</div>
        </div>
      </div>
    </details>

    <!-- Upper Body A -->
    <details class="fp-card">
      <summary class="fp-card-head">
        <span class="fp-icon">&#128170;</span>
        <span>Upper Body A <small>Monday</small></span>
      </summary>
      <div class="fp-card-body">
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Bench Press</div>
              <div class="fp-ex-sets">3 &times; 6&ndash;8</div>
              <div class="fp-ex-target">Chest &middot; Triceps &middot; Front shoulders</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=barbell+bench+press+proper+form+tutorial" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Feet flat, arch back slightly, grip just outside shoulders. Lower bar to mid-chest, press explosively. Don't bounce off chest.</div>
          <div class="fp-ex-rest">Rest 2&ndash;3 min</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Assisted Pull-Up</div>
              <div class="fp-ex-sets">2 &times; 8&ndash;12</div>
              <div class="fp-ex-target">Lats &middot; Upper back</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=assisted+pull+up+machine+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Pull elbows down and back, chest up. Squeeze shoulder blades at the top. Control the negative &mdash; 2&ndash;3 sec down.</div>
          <div class="fp-ex-rest">Rest 90s</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Incline Dumbbell Press</div>
              <div class="fp-ex-sets">2 &times; 8&ndash;12</div>
              <div class="fp-ex-target">Upper chest</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=incline+dumbbell+press+form+tutorial" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Bench at 30&ndash;45&deg;. Dumbbells at chest level, press up and slightly inward. Keep shoulders pinned back.</div>
          <div class="fp-ex-rest">Rest 90s</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Lat Pulldown</div>
              <div class="fp-ex-sets">2 &times; 8&ndash;12</div>
              <div class="fp-ex-target">Lats</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=lat+pulldown+proper+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Lean back slightly, pull bar to upper chest. Drive elbows down, don't swing. Squeeze lats at the bottom.</div>
          <div class="fp-ex-rest">Rest 90s</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Dumbbell Lateral Raise</div>
              <div class="fp-ex-sets">2 &times; 12&ndash;15</div>
              <div class="fp-ex-target">Side shoulders</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=dumbbell+lateral+raise+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Slight bend in elbows, raise to shoulder height. Lead with elbows, not hands. Light weight, feel the burn.</div>
          <div class="fp-ex-rest">Rest 60s</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Cable Crunch</div>
              <div class="fp-ex-sets">2 &times; 12&ndash;15</div>
              <div class="fp-ex-target">Abs</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=cable+crunch+abs+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Kneel facing cable, hold rope behind head. Crunch ribs toward hips &mdash; don't just bow. Hold bottom for 1 sec.</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Hanging Leg Raises</div>
              <div class="fp-ex-sets">2 sets to failure</div>
              <div class="fp-ex-target">Lower abs</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=hanging+leg+raise+form+beginner" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Hang from bar, raise knees to chest (or straight legs if able). Control the swing &mdash; no kipping. Good form over reps.</div>
        </div>
      </div>
    </details>

    <!-- Lower Body A -->
    <details class="fp-card">
      <summary class="fp-card-head">
        <span class="fp-icon">&#129461;</span>
        <span>Lower Body A <small>Tuesday</small></span>
      </summary>
      <div class="fp-card-body">
        <p class="fp-note">Knee-friendly. Don't go excessively deep on leg press &mdash; stop at 90&deg;.</p>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Leg Press</div>
              <div class="fp-ex-sets">3 &times; 10&ndash;12</div>
              <div class="fp-ex-target">Quads &middot; Glutes</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=leg+press+machine+proper+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Feet shoulder-width, mid-platform. Press through whole foot. Knees track over toes &mdash; don't let them cave in. Don't lock out knees at top.</div>
          <div class="fp-ex-rest">Rest 2 min</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Leg Extension</div>
              <div class="fp-ex-sets">2 &times; 12&ndash;15</div>
              <div class="fp-ex-target">Quads</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=leg+extension+machine+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Light weight only &mdash; this is for quad activation, not maxing out. Squeeze at the top for 1 sec. Slow negative.</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Hamstring Curl</div>
              <div class="fp-ex-sets">3 &times; 12&ndash;15</div>
              <div class="fp-ex-target">Hamstrings</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=lying+hamstring+curl+machine+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Lying or seated. Curl all the way up, squeeze hamstrings hard. 2&ndash;3 sec negative. Don't use momentum.</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Standing Calf Raise</div>
              <div class="fp-ex-sets">3 &times; 15&ndash;20</div>
              <div class="fp-ex-target">Calves</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=standing+calf+raise+machine+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Full stretch at bottom, pause 1 sec. Rise onto toes fully, squeeze at top. Slow and controlled &mdash; no bouncing.</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Plank</div>
              <div class="fp-ex-sets">3 &times; 30s</div>
              <div class="fp-ex-target">Core</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=plank+exercise+proper+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Forearms on floor, body straight line. Squeeze glutes and brace abs like someone's about to punch your gut. Don't let hips sag or pike up.</div>
        </div>
      </div>
    </details>

    <!-- Upper Body B -->
    <details class="fp-card">
      <summary class="fp-card-head">
        <span class="fp-icon">&#128170;</span>
        <span>Upper Body B <small>Thursday</small></span>
      </summary>
      <div class="fp-card-body">
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Overhead Press</div>
              <div class="fp-ex-sets">3 &times; 6&ndash;8</div>
              <div class="fp-ex-target">Shoulders &middot; Triceps</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=overhead+press+barbell+form+tutorial" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Standing or seated. Bar starts at collar bone, press straight up. Brace core tight &mdash; don't arch lower back. Tuck chin to let bar pass face.</div>
          <div class="fp-ex-rest">Rest 2&ndash;3 min</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">T-Bar Row</div>
              <div class="fp-ex-sets">2 &times; 6&ndash;8</div>
              <div class="fp-ex-target">Upper back &middot; Lats</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=t+bar+row+proper+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Hinge at hips ~45&deg;, flat back. Pull to lower chest, squeeze shoulder blades together. Don't yank &mdash; control the weight.</div>
          <div class="fp-ex-rest">Rest 2 min</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Knee Push-Ups</div>
              <div class="fp-ex-sets">2 sets AMRAP</div>
              <div class="fp-ex-target">Chest &middot; Triceps</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=knee+push+ups+proper+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Hands just outside shoulders, knees on floor. Lower chest to ground, press up. Keep core tight &mdash; body should be a straight line from knees to head.</div>
          <div class="fp-ex-rest">Rest 90s</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Seated Row</div>
              <div class="fp-ex-sets">2 &times; 8&ndash;12</div>
              <div class="fp-ex-target">Mid-back &middot; Rhomboids</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=seated+cable+row+proper+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Sit upright, pull handle to belly button. Lead with elbows, squeeze back. Don't lean back to cheat the weight.</div>
          <div class="fp-ex-rest">Rest 90s</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Pec Fly</div>
              <div class="fp-ex-sets">2 &times; 8&ndash;12</div>
              <div class="fp-ex-target">Chest</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=pec+fly+machine+or+dumbbell+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Machine or dumbbells. Slight bend in elbows, open arms wide, squeeze chest to bring arms together. Feel the stretch at the bottom.</div>
          <div class="fp-ex-rest">Rest 90s</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Rear Delt Fly</div>
              <div class="fp-ex-sets">2 &times; 15&ndash;20</div>
              <div class="fp-ex-target">Rear shoulders</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=rear+delt+fly+dumbbell+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Bent over or on machine. Arms out to sides, squeeze shoulder blades. Light weight, high reps &mdash; rear delts respond to volume.</div>
          <div class="fp-ex-rest">Rest 60s</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Dumbbell Shrugs</div>
              <div class="fp-ex-sets">2 &times; 12&ndash;15</div>
              <div class="fp-ex-target">Traps</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=dumbbell+shrugs+proper+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Hold dumbbells at sides, shrug straight up toward ears. Hold top for 1 sec. Don't roll shoulders &mdash; just up and down.</div>
        </div>
      </div>
    </details>

    <!-- Lower Body B -->
    <details class="fp-card">
      <summary class="fp-card-head">
        <span class="fp-icon">&#129461;</span>
        <span>Lower Body B <small>Friday</small></span>
      </summary>
      <div class="fp-card-body">
        <p class="fp-note">Knee-friendly session. Listen to your body.</p>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Glute Bridge</div>
              <div class="fp-ex-sets">3 &times; 8&ndash;12</div>
              <div class="fp-ex-target">Glutes</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=barbell+glute+bridge+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Back on bench, feet flat on floor. Drive hips up by squeezing glutes &mdash; don't hyperextend lower back. Pause 1 sec at top.</div>
          <div class="fp-ex-rest">Rest 90s</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Leg Press</div>
              <div class="fp-ex-sets">3 &times; 10&ndash;15</div>
              <div class="fp-ex-target">Quads &middot; Glutes</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=leg+press+machine+proper+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Same as Lower A. Feet mid-platform, shoulder-width. Controlled descent to 90&deg;, push through whole foot.</div>
          <div class="fp-ex-rest">Rest 2 min</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Hamstring Curl</div>
              <div class="fp-ex-sets">2 &times; 10&ndash;12</div>
              <div class="fp-ex-target">Hamstrings</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=lying+hamstring+curl+machine+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Full range of motion. Curl hard, slow release. Focus on the hamstring contraction, not moving weight.</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Seated Calf Raise</div>
              <div class="fp-ex-sets">3 &times; 15&ndash;20</div>
              <div class="fp-ex-target">Soleus (lower calf)</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=seated+calf+raise+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Seated version targets the soleus (deep calf). Full stretch at bottom, pause, rise fully. Don't rush the reps.</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Hammer Curl</div>
              <div class="fp-ex-sets">2 &times; 12&ndash;15</div>
              <div class="fp-ex-target">Biceps &middot; Brachialis</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=dumbbell+hammer+curl+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Palms face each other (neutral grip). Curl up without swinging body. Keep elbows pinned to sides.</div>
          <div class="fp-ex-rest">Rest 60s</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Overhead Tricep Extension</div>
              <div class="fp-ex-sets">2 &times; 12&ndash;15</div>
              <div class="fp-ex-target">Triceps</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=overhead+tricep+extension+dumbbell+form" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">One dumbbell with both hands overhead. Lower behind head, elbows pointing up. Extend fully, squeeze triceps at top.</div>
          <div class="fp-ex-rest">Rest 60s</div>
        </div>
        <div class="fp-exercise">
          <div class="fp-ex-top">
            <div>
              <div class="fp-ex-name">Side Plank</div>
              <div class="fp-ex-sets">2 each side &times; 20&ndash;30s</div>
              <div class="fp-ex-target">Obliques &middot; Core stability</div>
            </div>
            <a class="fp-demo" href="https://www.youtube.com/results?search_query=side+plank+proper+form+beginner" target="_blank" rel="noopener">Demo &#8599;</a>
          </div>
          <div class="fp-ex-detail">Forearm on floor, feet stacked or staggered. Hips up, body straight line. Don't let hips drop. Breathe normally.</div>
        </div>
      </div>
    </details>

    </div>
  </div>

  <!-- ==================== TRACK TAB ==================== -->
  <div class="fp-panel" id="panel-track">
    <div class="fp-grid fp-grid--single">

    <!-- Log Entry -->
    <div class="fp-card fp-card--open">
      <div class="fp-card-head fp-card-head--static">
        <span class="fp-icon">&#128221;</span>
        <span>Log Today</span>
      </div>
      <div class="fp-card-body">
        <div class="fp-form">
          <div class="fp-form-row">
            <label class="fp-label" for="log-date">Date</label>
            <input class="fp-input" type="date" id="log-date" />
          </div>
          <div class="fp-form-row">
            <label class="fp-label" for="log-weight">Weight (kg)</label>
            <input class="fp-input" type="number" id="log-weight" step="0.1" min="50" max="200" placeholder="e.g. 129.5" />
          </div>
          <div class="fp-form-row">
            <label class="fp-label" for="log-knee">Knee Pain (0&ndash;10)</label>
            <input class="fp-input" type="number" id="log-knee" step="1" min="0" max="10" placeholder="0 = none" />
          </div>
          <div class="fp-form-row">
            <label class="fp-label" for="log-waist">Waist at navel (cm) <small>optional</small></label>
            <input class="fp-input" type="number" id="log-waist" step="0.1" placeholder="Sunday only" />
          </div>
          <button class="fp-btn" id="log-save">Save Entry</button>
        </div>
      </div>
    </div>

    <!-- History -->
    <div class="fp-card fp-card--open">
      <div class="fp-card-head fp-card-head--static">
        <span class="fp-icon">&#128200;</span>
        <span>Progress</span>
        <button class="fp-clear-btn" id="log-clear">Clear All</button>
      </div>
      <div class="fp-card-body">
        <div class="fp-progress-summary" id="progress-summary"></div>
        <div class="fp-table-wrap">
          <table class="fp-table" id="log-table">
            <thead>
              <tr>
                <th>Date</th>
                <th>Weight</th>
                <th>Knee</th>
                <th>Waist</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="log-body"></tbody>
          </table>
        </div>
        <p class="fp-empty-msg" id="log-empty">No entries yet. Start logging above!</p>
      </div>
    </div>

    </div>
  </div>

  <!-- ==================== EXTRAS TAB ==================== -->
  <div class="fp-panel" id="panel-extras">
    <div class="fp-grid">

    <!-- Steps -->
    <div class="fp-card fp-card--open">
      <div class="fp-card-head fp-card-head--static">
        <span class="fp-icon">&#128694;</span>
        <span>Daily Steps</span>
      </div>
      <div class="fp-card-body">
        <p class="fp-note">Don't chase 10k immediately &mdash; protect your knee.</p>
        <div class="fp-steps-grid">
          <div class="fp-step-week">
            <span class="fp-step-label">Week 1</span>
            <span class="fp-step-val">5,000&ndash;6,000</span>
          </div>
          <div class="fp-step-week">
            <span class="fp-step-label">Week 2</span>
            <span class="fp-step-val">6,000</span>
          </div>
          <div class="fp-step-week">
            <span class="fp-step-label">Week 3</span>
            <span class="fp-step-val">7,000</span>
          </div>
          <div class="fp-step-week fp-step-week--target">
            <span class="fp-step-label">Week 4+</span>
            <span class="fp-step-val">8,000</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Progress Tracking -->
    <div class="fp-card fp-card--open">
      <div class="fp-card-head fp-card-head--static">
        <span class="fp-icon">&#128200;</span>
        <span>What to Track</span>
      </div>
      <div class="fp-card-body">
        <h4>Every Morning (after washroom)</h4>
        <ul class="fp-checklist">
          <li>Weight</li>
          <li>Knee pain (0&ndash;10)</li>
        </ul>
        <h4>Every Sunday</h4>
        <ul class="fp-checklist">
          <li>Waist at navel</li>
          <li>Waist below navel</li>
          <li>Weekly average weight</li>
        </ul>
      </div>
    </div>

    <!-- Success Markers -->
    <div class="fp-card fp-card--open">
      <div class="fp-card-head fp-card-head--static">
        <span class="fp-icon">&#127942;</span>
        <span>Success Markers</span>
      </div>
      <div class="fp-card-body">
        <ul class="fp-checklist fp-checklist--success">
          <li>Weight trending down</li>
          <li>Waist shrinking</li>
          <li>Strength increasing</li>
          <li>Knee pain stable or improving</li>
        </ul>
        <p class="fp-target-note">
          12-week target: <strong>118&ndash;122 kg</strong>
        </p>
      </div>
    </div>

    </div>
  </div>

</div>
</Layout>

<style>
  /* ===== Base ===== */
  .fp {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1rem 6rem;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    -webkit-tap-highlight-color: transparent;
  }

  /* ===== Header ===== */
  .fp-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem 0 1rem;
    position: sticky;
    top: 0;
    z-index: 100;
    background: #0a0a0f;
  }
