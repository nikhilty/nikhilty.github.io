  /* ===== Tracker Table ===== */
  .fp-table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .fp-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
  .fp-table th { text-align: left; color: #5c5c70; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em; padding: 0.5rem 0.5rem; border-bottom: 1px solid #2a2a3d; }
  .fp-table td { padding: 0.5rem 0.5rem; color: #d0d0dd; border-bottom: 1px solid #1e1e2e; }
  .fp-table .fp-del-btn { background: none; border: none; color: #5c5c70; cursor: pointer; font-size: 0.9rem; padding: 0.2rem; line-height: 1; }
  .fp-table .fp-del-btn:hover { color: #f87171; }
  .fp-empty-msg { font-size: 0.85rem; color: #5c5c70; text-align: center; padding: 1.5rem 0; }
  .fp-progress-summary {
    display: none;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .fp-progress-summary.has-data { display: grid; }
  .fp-stat-card {
    text-align: center;
    padding: 0.6rem 0.4rem;
    background: #1c1c28;
    border: 1px solid #2a2a3d;
    border-radius: 10px;
  }
  .fp-stat-label { display: block; font-size: 0.65rem; font-weight: 600; text-transform: uppercase; color: #5c5c70; margin-bottom: 0.15rem; }
  .fp-stat-value { display: block; font-size: 1.1rem; font-weight: 700; color: #f0f0f5; }
  .fp-stat-value--green { color: #86efac; }
  .fp-stat-value--red { color: #fca5a5; }
  .fp-clear-btn {
    margin-left: auto;
    padding: 0.2rem 0.6rem;
    background: none;
    border: 1px solid #2a2a3d;
    border-radius: 6px;
    color: #5c5c70;
    font-size: 0.7rem;
    font-family: inherit;
    cursor: pointer;
  }
  .fp-clear-btn:hover { color: #f87171; border-color: rgba(248, 113, 113, 0.3); }

  /* ===== Desktop ===== */
  @media (min-width: 768px) {
    .fp { padding: 0 2.5rem 4rem; }
    .fp-header { padding: 2rem 0 1.25rem; }
    .fp-title { font-size: 1.8rem; }
    .fp-stats { font-size: 0.9rem; }
    .fp-tabs { top: 76px; padding: 1rem 0; }
    .fp-tab { padding: 0.6rem 1.5rem; font-size: 0.95rem; }
    .fp-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    .fp-grid--single { grid-template-columns: repeat(2, 1fr); }
    .fp-card--full { grid-column: 1 / -1; }
    .fp-card-head { padding: 1rem 1.25rem; font-size: 1.05rem; }
    .fp-card-body { padding: 0 1.25rem 1.25rem; }
    .fp-card-body h4 { font-size: 0.8rem; }
    .fp-chip { font-size: 0.85rem; padding: 0.35rem 0.8rem; }
    .fp-options li { font-size: 0.9rem; }
    .fp-ex-name { font-size: 1rem; }
    .fp-ex-sets { font-size: 0.9rem; }
    .fp-ex-detail { font-size: 0.85rem; }
    .fp-note { font-size: 0.88rem; }
    .fp-steps-grid { grid-template-columns: repeat(4, 1fr); }
    .fp-step-val { font-size: 1.15rem; }
    .fp-checklist li { font-size: 0.9rem; }
    .fp-form-row { flex-direction: row; align-items: center; gap: 0.75rem; }
    .fp-label { min-width: 160px; }
    .fp-input { flex: 1; }
    .fp-progress-summary { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 400px) {
    .fp-schedule { grid-template-columns: repeat(4, 1fr); }
  }
</style>

<script>
  // Tab switching
  document.getElementById('tabs')!.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.fp-tab');
    if (!btn) return;
    const tab = btn.getAttribute('data-tab')!;
    document.querySelectorAll('.fp-tab').forEach(t => t.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.fp-panel').forEach(p => p.classList.remove('active'));
    document.getElementById(`panel-${tab}`)!.classList.add('active');
    if (tab === 'track') renderLog();
  });

  // Weight tracker with localStorage
  const STORAGE_KEY = 'fp-weight-log';

  interface LogEntry {
    date: string;
    weight: number;
    knee: number;
    waist?: number;
  }

  function getLog(): LogEntry[] {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); }
    catch { return []; }
  }

  function saveLog(log: LogEntry[]) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(log));
  }

  function renderLog() {
    const log = getLog().sort((a, b) => b.date.localeCompare(a.date));
    const body = document.getElementById('log-body')!;
    const empty = document.getElementById('log-empty')!;
    const summary = document.getElementById('progress-summary')!;

    body.innerHTML = '';

    if (log.length === 0) {
      empty.style.display = 'block';
      summary.classList.remove('has-data');
      return;
    }

    empty.style.display = 'none';

    // Summary stats
    const latest = log[0];
    const oldest = log[log.length - 1];
    const weekEntries = log.filter(e => {
      const d = new Date(e.date);
      const now = new Date();
      return (now.getTime() - d.getTime()) < 7 * 86400000;
    });
    const weekAvg = weekEntries.length > 0
      ? (weekEntries.reduce((s, e) => s + e.weight, 0) / weekEntries.length).toFixed(1)
      : latest.weight.toFixed(1);
    const totalChange = log.length > 1 ? (latest.weight - oldest.weight).toFixed(1) : '0.0';
    const changeNum = parseFloat(totalChange);
    const changeClass = changeNum < 0 ? 'fp-stat-value--green' : changeNum > 0 ? 'fp-stat-value--red' : '';
    const changePrefix = changeNum > 0 ? '+' : '';

    summary.classList.add('has-data');
    summary.innerHTML = `
      <div class="fp-stat-card">
        <span class="fp-stat-label">Latest</span>
        <span class="fp-stat-value">${latest.weight} kg</span>
      </div>
      <div class="fp-stat-card">
        <span class="fp-stat-label">7-Day Avg</span>
        <span class="fp-stat-value">${weekAvg} kg</span>
      </div>
      <div class="fp-stat-card">
        <span class="fp-stat-label">Total Change</span>
        <span class="fp-stat-value ${changeClass}">${changePrefix}${totalChange} kg</span>
      </div>
    `;

    // Table rows
    log.forEach((entry, i) => {
      const tr = document.createElement('tr');
      const d = new Date(entry.date + 'T00:00:00');
      const dateStr = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      const kneeColor = entry.knee <= 2 ? '#86efac' : entry.knee <= 5 ? '#fbbf24' : '#fca5a5';
      tr.innerHTML = `
        <td>${dateStr}</td>
        <td><strong>${entry.weight}</strong></td>
        <td style="color:${kneeColor}">${entry.knee}/10</td>
        <td>${entry.waist ? entry.waist + ' cm' : '—'}</td>
        <td><button class="fp-del-btn" data-idx="${i}">&times;</button></td>
      `;
      body.appendChild(tr);
    });
  }

  // Save entry
  document.getElementById('log-save')!.addEventListener('click', () => {
    const dateEl = document.getElementById('log-date') as HTMLInputElement;
    const weightEl = document.getElementById('log-weight') as HTMLInputElement;
    const kneeEl = document.getElementById('log-knee') as HTMLInputElement;
    const waistEl = document.getElementById('log-waist') as HTMLInputElement;

    const weight = parseFloat(weightEl.value);
    const knee = parseInt(kneeEl.value);
    if (!dateEl.value || isNaN(weight) || isNaN(knee)) return;

    const log = getLog();
    const existing = log.findIndex(e => e.date === dateEl.value);
    const entry: LogEntry = {
      date: dateEl.value,
      weight,
      knee,
      waist: waistEl.value ? parseFloat(waistEl.value) : undefined,
    };
    if (existing >= 0) log[existing] = entry;
    else log.push(entry);
    saveLog(log);

    weightEl.value = '';
    kneeEl.value = '';
    waistEl.value = '';
    renderLog();
  });

  // Delete entry
  document.getElementById('log-body')!.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.fp-del-btn');
    if (!btn) return;
    const idx = parseInt(btn.getAttribute('data-idx')!);
    const log = getLog().sort((a, b) => b.date.localeCompare(a.date));
    log.splice(idx, 1);
    saveLog(log);
    renderLog();
  });

  // Clear all
  document.getElementById('log-clear')!.addEventListener('click', () => {
    if (confirm('Delete all tracking data? This cannot be undone.')) {
      localStorage.removeItem(STORAGE_KEY);
      renderLog();
    }
  });

  // Set today's date as default
  const dateInput = document.getElementById('log-date') as HTMLInputElement;
  const today = new Date();
  dateInput.value = today.getFullYear() + '-' +
    String(today.getMonth() + 1).padStart(2, '0') + '-' +
    String(today.getDate()).padStart(2, '0');

  // Initial render if track tab is visible
  renderLog();
</script>
