---
const skillCategories = [
  {
    title: "Languages",
    skills: ["Java", "Rust", "Python", "TypeScript", "SQL", "Go"],
  },
  {
    title: "Distributed Systems",
    skills: ["PostgreSQL Internals", "Aurora", "CDC", "Kafka", "Flink", "Airflow"],
  },
  {
    title: "Cloud & Infrastructure",
    skills: ["AWS (Aurora, S3, EC2, IAM)", "Azure", "Kubernetes", "Docker", "Terraform"],
  },
  {
    title: "Observability & OS",
    skills: ["Prometheus", "Grafana", "Distributed Logging", "Linux (Ubuntu, Red Hat)", "macOS"],
  },
];
---

<section id="skills" class="skills">
  <div class="container">
    <div class="animate-in">
      <span class="section-label">Skills</span>
      <h2 class="section-title">My toolkit</h2>
      <p class="section-subtitle">Technologies and systems I've built with, operated, and gone deep on over the past decade.</p>
    </div>
    <div class="skills-grid">
      {skillCategories.map((cat, i) => (
        <div class="skill-category animate-in" style={`transition-delay: ${i * 0.1}s`}>
          <h3 class="skill-category-title">{cat.title}</h3>
          <div class="skill-list">
            {cat.skills.map((skill) => (
              <div class="skill-item">
                <span class="skill-dot"></span>
                {skill}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills {
    background: var(--bg-primary);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .skill-category {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    transition: all var(--transition);
  }

  .skill-category:hover {
    border-color: var(--accent);
  }

  .skill-category-title {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-light);
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .skill-list {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .skill-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: var(--text-secondary);
    transition: color var(--transition);
  }

  .skill-item:hover {
    color: var(--text-primary);
  }

  .skill-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  .skill-item:hover .skill-dot {
    box-shadow: 0 0 8px var(--accent-glow-strong);
  }

  @media (max-width: 768px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
