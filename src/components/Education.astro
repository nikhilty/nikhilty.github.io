---

---

<section id="education" class="education">
  <div class="container">
    <div class="education-content animate-in">
      <span class="section-label">Education</span>
      <h2 class="section-title">Background</h2>
    </div>
    <div class="education-card animate-in">
      <div class="edu-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 0 3 3 6 3s6-3 6-3v-5"/>
        </svg>
      </div>
      <div>
        <h3 class="edu-degree">Bachelor of Engineering</h3>
        <p class="edu-field">Computer Science & Engineering</p>
        <p class="edu-school">Nitte Meenakshi Institute of Technology, Bangalore, India</p>
        <span class="edu-period">2011 — 2015</span>
      </div>
    </div>
  </div>
</section>

<style>
  .education {
    background: var(--bg-secondary);
    padding-bottom: 4rem;
  }

  .education-card {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    margin-top: 2rem;
    padding: 2rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    max-width: 600px;
    transition: all var(--transition);
  }

  .education-card:hover {
    border-color: var(--accent);
  }

  .edu-icon {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-glow);
    border-radius: 14px;
    color: var(--accent-light);
  }

  .edu-degree {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.2rem;
  }

  .edu-field {
    font-size: 0.95rem;
    color: var(--accent-light);
    font-weight: 500;
    margin-bottom: 0.4rem;
  }

  .edu-school {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .edu-period {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    padding: 0.2rem 0.6rem;
    background: var(--bg-secondary);
    border-radius: 100px;
    border: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .education-card {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
