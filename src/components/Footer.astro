---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <p class="footer-text">
      <span class="footer-name">&lt;NT /&gt;</span>
      <span class="footer-divider">&middot;</span>
      Designed & built by Nikhil Tyagi
    </p>
    <p class="footer-copy">&copy; {year}</p>
  </div>
</footer>

<style>
  .footer {
    padding: 2rem 0;
    border-top: 1px solid var(--border);
    background: var(--bg-primary);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-text {
    font-size: 0.85rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-name {
    font-family: var(--font-mono);
    color: var(--accent-light);
    font-weight: 500;
  }

  .footer-divider {
    opacity: 0.3;
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .footer-inner {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>
